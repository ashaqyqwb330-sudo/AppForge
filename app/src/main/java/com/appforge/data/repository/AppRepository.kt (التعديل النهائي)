package com.appforge.data.repository

import android.content.Context
import com.appforge.data.local.AppInstanceDao
import com.appforge.domain.model.AppInstance
import kotlinx.coroutines.flow.Flow
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class AppRepository @Inject constructor(
    private val dao: AppInstanceDao,
    private val fileManager: DatabaseFileManager,
    private val context: Context  // سيحقنه Hilt تلقائيًا من ApplicationContext
) {
    fun getAllInstances(): Flow<List<AppInstance>> = dao.getAllInstances()

    suspend fun getActiveInstance(): AppInstance? = dao.getActiveInstance()

    suspend fun getInstanceById(id: Long): AppInstance? = dao.getInstanceById(id)

    suspend fun addInstance(instance: AppInstance): Long = dao.insertInstance(instance)

    suspend fun updateInstance(instance: AppInstance) = dao.updateInstance(instance)

    suspend fun deleteInstance(instance: AppInstance) {
        if (instance.dbFilePath.startsWith(context.filesDir.absolutePath)) {
            fileManager.deleteDatabase(instance.dbFilePath)
        }
        dao.deleteInstance(instance)
    }

    suspend fun setActiveInstance(id: Long) {
        dao.deactivateAll()
        dao.activateInstance(id)
    }

    suspend fun renameInstance(id: Long, newName: String) {
        val instance = dao.getInstanceById(id)
        instance?.let {
            dao.updateInstance(it.copy(name = newName))
        }
    }
}
